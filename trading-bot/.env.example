# Anthropic Claude API — required for real LLM analysis (predictions + lessons)
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Finnhub — free tier covers earnings calendar + company metrics
# Get one at https://finnhub.io/register
FINNHUB_API_KEY=

# Reddit API — free, OAuth "script" app
# Create at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# X (Twitter) API v2 Bearer Token — REQUIRES PAID PLAN
# Free tier is read-zero. Basic plan starts at ~$200/month.
# https://developer.x.com/
TWITTER_BEARER_TOKEN=

# Yahoo Finance is used automatically. No key needed.
# IEX Cloud retired in August 2024 — Finnhub replaces it here.

PORT=3001
FRONTEND_URL=http://localhost:5173
