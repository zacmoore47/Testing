generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── User Profile & Goals ──────────────────────────────────────────────────

model UserProfile {
  id        Int      @id @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  targetSleepHours      Float  @default(8)
  targetBedtime         String @default("22:30")
  targetWaketime        String @default("06:30")
  targetWorkoutsPerWeek Int    @default(5)
  targetProtein         Float  @default(180)
  targetCarbs           Float  @default(250)
  targetFats            Float  @default(70)
  targetCalories        Float  @default(2400)
  targetWater           Float  @default(100)
  targetDailySpend      Float  @default(100)
  targetMonthlySavings  Float  @default(3000)
  targetWeight          Float  @default(180)
  targetProjectHours    Float  @default(4)
  maxCaffeineMg         Float  @default(200)
  overallGoals          String @default("Optimize performance across all life sectors. Build a successful business while maintaining peak physical and mental health.")
}

// ─── Daily Log (core anchor for biometric data) ────────────────────────────

model DailyLog {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sleep         Sleep?
  workout       Workout?
  stimulants    Stimulants?
  macros        Macros?
  supplements   Supplement[]
  healthMetrics HealthMetrics?
  dailyScore    DailyScore?
}

// ─── Sleep (simplified) ───────────────────────────────────────────────────

model Sleep {
  id         Int      @id @default(autoincrement())
  dailyLog   DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  dailyLogId Int      @unique

  hours    Float
  quality  Int     // 1-10 subjective
  bedtime  String  // "22:30"
  waketime String  // "06:30"
  notes    String?
}

// ─── Workout (simplified) ─────────────────────────────────────────────────

model Workout {
  id         Int      @id @default(autoincrement())
  dailyLog   DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  dailyLogId Int      @unique

  type         String  // strength | cardio | mobility | hiit | rest
  duration     Int     // minutes
  intensity    Int     // 1-10
  muscleGroups String?
  notes        String?
}

// ─── Stimulants ───────────────────────────────────────────────────────────

model Stimulants {
  id         Int      @id @default(autoincrement())
  dailyLog   DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  dailyLogId Int      @unique

  caffeineMg   Float  @default(0)
  nicotineMg   Float  @default(0)
  other        String?
  timeConsumed String?
  notes        String?
}

// ─── Nutrition ────────────────────────────────────────────────────────────

model Macros {
  id         Int      @id @default(autoincrement())
  dailyLog   DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  dailyLogId Int      @unique

  protein   Float
  carbs     Float
  fats      Float
  calories  Float
  waterOz   Float @default(0)
  mealCount Int   @default(3)
  notes     String?
}

model Supplement {
  id         Int      @id @default(autoincrement())
  dailyLog   DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  dailyLogId Int

  name  String
  dose  String
  time  String?
  taken Boolean @default(false)
}

// ─── Health Metrics ───────────────────────────────────────────────────────

model HealthMetrics {
  id         Int      @id @default(autoincrement())
  dailyLog   DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  dailyLogId Int      @unique

  weight     Float?
  bodyFatPct Float?
  mood       Int?
  energy     Int?
  stress     Int?
  focus      Int?
  systolic   Int?
  diastolic  Int?
  glucose    Float?
  notes      String?
}

// ─── Finance (rebuilt) ────────────────────────────────────────────────────

model Expense {
  id          Int      @id @default(autoincrement())
  date        DateTime
  amount      Float
  category    String   // Food | Transport | Subscriptions | Entertainment | Bills | Shopping | Health | Other
  description String?
  createdAt   DateTime @default(now())
}

model Income {
  id          Int      @id @default(autoincrement())
  date        DateTime
  amount      Float
  source      String
  description String?
  createdAt   DateTime @default(now())
}

// ─── Projects (rebuilt entrepreneurial) ──────────────────────────────────

model Project {
  id                   Int          @id @default(autoincrement())
  name                 String
  description          String?
  status               String       @default("Active") // Active | Paused | Completed | Archived
  priority             Int          @default(3)        // 1-5
  color                String       @default("#60a5fa")
  targetCompletionDate DateTime?
  createdAt            DateTime     @default(now())
  logs                 ProjectLog[]
  tasks                Task[]
}

model ProjectLog {
  id               Int      @id @default(autoincrement())
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId        Int
  date             DateTime
  hoursWorked      Float
  whatWasCompleted String
  blockers         String?
  nextStep         String?
  createdAt        DateTime @default(now())
}

// ─── Habits ───────────────────────────────────────────────────────────────

model Habit {
  id              Int               @id @default(autoincrement())
  name            String
  icon            String            @default("check")
  color           String            @default("#60a5fa")
  targetFrequency String            @default("Daily") // Daily | Weekdays | custom
  active          Boolean           @default(true)
  order           Int               @default(0)
  createdAt       DateTime          @default(now())
  completions     HabitCompletion[]
}

model HabitCompletion {
  id        Int      @id @default(autoincrement())
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  habitId   Int
  date      DateTime
  completed Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([habitId, date])
}

// ─── Daily Score (9 sectors) ──────────────────────────────────────────────

model DailyScore {
  id         Int      @id @default(autoincrement())
  dailyLog   DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  dailyLogId Int      @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sleepScore           Float  @default(0)
  workoutScore         Float  @default(0)
  stimulantsScore      Float  @default(0)
  macrosScore          Float  @default(0)
  supplementsScore     Float  @default(0)
  financesScore        Float  @default(0)
  healthScore          Float  @default(0)
  entrepreneurialScore Float  @default(0)
  habitScore           Float  @default(0)
  overallScore         Float  @default(0)

  recommendation         String?
  priorityAction         String?
  warnings               String?
  topTaskRecommendation  String?
  dataHash               String?
}

// ─── Tasks ────────────────────────────────────────────────────────────────

model Task {
  id               Int       @id @default(autoincrement())
  title            String
  description      String?
  priority         Int       @default(3) // 1=highest, 5=lowest
  status           String    @default("Pending") // Pending | InProgress | Completed | Cancelled
  dueDate          DateTime?
  projectId        Int?
  project          Project?  @relation(fields: [projectId], references: [id])
  estimatedMinutes Int?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  order            Int       @default(0)

  @@index([status, priority, order])
}
