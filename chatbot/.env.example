ANTHROPIC_API_KEY=your_anthropic_api_key_here
PORT=3000

# CORS: comma-separated list of allowed domains (leave empty to allow all)
# ALLOWED_ORIGINS=https://client1.com,https://client2.com

# Email for human handoff (Gmail recommended)
# For Gmail: enable 2FA then create an App Password at myaccount.google.com/apppasswords
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
